{
  "name": "bbg",
  "version": "0.1.0",
  "description": "AI development automation workflow governance toolkit",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "ai",
    "workflow",
    "automation",
    "governance",
    "typescript"
  ],
  "author": "buzzxu",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
